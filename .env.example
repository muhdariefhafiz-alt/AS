# FairComparisons (agentscan-sg) environment variables.
# Copy to .env.local and fill in real values. NEVER commit the filled-in file.
# Production values live in Vercel → Project → Settings → Environment Variables.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # public by design (RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=            # SECRET, bypasses RLS, server-only

# --- Site ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_BASE_URL=

# --- Admin auth ---
ADMIN_EMAIL=
ADMIN_EMAILS=                         # comma-separated allowlist
ADMIN_SECRET=                         # HMAC session signing key (openssl rand -hex 32)

# --- Jobs / security ---
CRON_SECRET=                          # bearer token Vercel cron must present
IP_HASH_SALT=                         # salt for hashing stored IPs

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# --- Email ---
# Transactional email sends via Resend when RESEND_API_KEY is set (requires a
# verified sending domain in Resend). Klaviyo is the legacy fallback: it only
# fires events, and mail goes out ONLY if a Klaviyo Flow exists for that metric.
RESEND_API_KEY=
RESEND_FROM=                          # e.g. "FairComparisons <noreply@fair-comparisons.com>"
KLAVIYO_API_KEY=

# --- WhatsApp Business ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Rate limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Scraping / data ---
APIFY_TOKEN=

# --- Google (indexing + Search Console) ---
GOOGLE_INDEXING_KEY=
GSC_SA_EMAIL=
GSC_SA_PRIVATE_KEY=
GSC_SITE_URL=

# --- DataForSEO AI-answer tracker (admin "AI Search" tab) ---
# Same account as the NL sibling; spend logged to the shared dataforseo_usage
# ledger, scoped to job='sg_ai_tracker'. Dormant until login + password are set.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_AI_MONTHLY_CAP_USD=10
DATAFORSEO_AI_DISABLED=
DATAFORSEO_AI_MAX_QUERIES_PER_RUN=60

# --- PayNow invoicing ---
FC_BANK_ACCOUNT=
FC_BANK_NAME=
FC_PAYNOW_UEN=
